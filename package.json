{
  "name": "baker-street-tasks",
  "private": true,
  "scripts": {
    "dev": "./scripts/dev.sh",
    "dev:services": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "turbo db:migrate --filter=@baker-street/db",
    "db:seed": "turbo db:seed --filter=@baker-street/db",
    "db:studio": "turbo db:studio --filter=@baker-street/db"
  },
  "devDependencies": {
    "turbo": "^2.4",
    "typescript": "^5.7"
  },
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
