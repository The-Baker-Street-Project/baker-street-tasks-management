{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["PGLITE_DATA_DIR", "MCP_API_KEY", "MCP_PORT", "NEXT_PUBLIC_APP_URL"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:migrate": {
      "cache": false,
      "passThroughEnv": ["PGLITE_DATA_DIR"]
    },
    "db:seed": {
      "cache": false,
      "passThroughEnv": ["PGLITE_DATA_DIR"]
    },
    "db:studio": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["PGLITE_DATA_DIR"]
    }
  }
}
